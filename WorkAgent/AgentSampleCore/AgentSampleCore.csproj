<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>AgentSampleCore</RootNamespace>
    <!-- 全サンプルで共有するシークレットの設定先(dotnet user-secrets の対象プロジェクト)。
         実行時はエントリ(各 Feature exe)の UserSecretsId が使われるが、同じ値を共有している。 -->
    <UserSecretsId>agent-sample</UserSecretsId>
    <CodeAnalysisRuleSet>..\Analyzers.ruleset</CodeAnalysisRuleSet>
  </PropertyGroup>

  <ItemGroup>
    <!-- Microsoft Agent Framework 1.0 GA。各サンプルはこのライブラリ経由でパッケージを参照する。 -->
    <PackageReference Include="Microsoft.Agents.AI" Version="1.10.0" />
    <PackageReference Include="Microsoft.Agents.AI.OpenAI" Version="1.10.0" />
    <!-- Microsoft Foundry の chat デプロイメントへ APIキーで接続するため -->
    <PackageReference Include="Azure.AI.OpenAI" Version="2.1.0" />
    <!-- 接続情報を appsettings.json / ユーザーシークレット / 環境変数 から読み込むため -->
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="10.0.9" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" Version="10.0.9" />
    <PackageReference Include="Microsoft.Extensions.Configuration.EnvironmentVariables" Version="10.0.9" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="10.0.9" />
    <PackageReference Include="Microsoft.Extensions.Configuration.UserSecrets" Version="10.0.9" />
  </ItemGroup>

</Project>
