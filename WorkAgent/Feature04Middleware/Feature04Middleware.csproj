<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Feature04Middleware</RootNamespace>
    <UserSecretsId>agent-sample</UserSecretsId>
    <CodeAnalysisRuleSet>..\Analyzers.ruleset</CodeAnalysisRuleSet>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\AgentSampleCore\AgentSampleCore.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\AgentSampleCore\GlobalSuppressions.cs" Link="GlobalSuppressions.cs" />
    <None Include="..\AgentSampleCore\appsettings.json" Link="appsettings.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
