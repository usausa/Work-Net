<Window
    x:Class="WorkWifi.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WorkWifi"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="WiFi アクセスポイント"
    Width="980"
    Height="720"
    Background="#1A1B26"
    FontFamily="Segoe UI"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType"
    mc:Ignorable="d">

    <Window.DataContext>
        <local:MainWindowViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <Border
            Grid.Row="0"
            Background="#16161E"
            BorderBrush="#414868"
            BorderThickness="0,0,0,1">
            <Grid Margin="24,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="30"
                    Text="📡" />

                <StackPanel
                    Grid.Column="1"
                    Margin="14,0,0,0"
                    VerticalAlignment="Center">
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="#C0CAF5"
                        Text="WiFi アクセスポイント" />
                    <TextBlock
                        FontSize="12"
                        Foreground="#9AA5CE"
                        Text="周辺で検出されたネットワーク" />
                </StackPanel>

                <Border
                    Grid.Column="2"
                    Padding="14,7"
                    VerticalAlignment="Center"
                    Background="#7AA2F7"
                    CornerRadius="14">
                    <TextBlock
                        FontSize="13"
                        FontWeight="Bold"
                        Foreground="#1A1B26">
                        <Run Text="📶 " />
                        <Run Text="{Binding AccessPoints.Count, Mode=OneWay}" />
                        <Run Text=" 件 検出" />
                    </TextBlock>
                </Border>
            </Grid>
        </Border>

        <!--  AP List  -->
        <ScrollViewer
            Grid.Row="1"
            Padding="12,8,12,12"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding AccessPoints}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:WifiAccessPoint}">
                        <Border
                            Margin="0,4"
                            Padding="16,12"
                            Background="#24283B"
                            BorderBrush="#414868"
                            BorderThickness="1"
                            CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  Signal indicator  -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="30"
                                        Foreground="{Binding SignalBrush}"
                                        Text="{Binding SignalIcon}" />
                                    <StackPanel
                                        Margin="0,2,0,0"
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal">
                                        <Rectangle
                                            Width="6"
                                            Height="5"
                                            Margin="1,0"
                                            VerticalAlignment="Bottom"
                                            Fill="{Binding SignalBrush}"
                                            Opacity="{Binding Bar1Opacity}"
                                            RadiusX="1"
                                            RadiusY="1" />
                                        <Rectangle
                                            Width="6"
                                            Height="9"
                                            Margin="1,0"
                                            VerticalAlignment="Bottom"
                                            Fill="{Binding SignalBrush}"
                                            Opacity="{Binding Bar2Opacity}"
                                            RadiusX="1"
                                            RadiusY="1" />
                                        <Rectangle
                                            Width="6"
                                            Height="13"
                                            Margin="1,0"
                                            VerticalAlignment="Bottom"
                                            Fill="{Binding SignalBrush}"
                                            Opacity="{Binding Bar3Opacity}"
                                            RadiusX="1"
                                            RadiusY="1" />
                                        <Rectangle
                                            Width="6"
                                            Height="17"
                                            Margin="1,0"
                                            VerticalAlignment="Bottom"
                                            Fill="{Binding SignalBrush}"
                                            Opacity="{Binding Bar4Opacity}"
                                            RadiusX="1"
                                            RadiusY="1" />
                                    </StackPanel>
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="12"
                                        FontWeight="Bold"
                                        Foreground="{Binding SignalBrush}"
                                        Text="{Binding SignalLabel}" />
                                </StackPanel>

                                <!--  Vertical separator  -->
                                <Rectangle
                                    Grid.Column="1"
                                    Width="1"
                                    Margin="8,4,16,4"
                                    Fill="#414868" />

                                <!--  Main info  -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">

                                    <!--  SSID + connection / hidden badges  -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock
                                            FontSize="18"
                                            FontWeight="SemiBold"
                                            Foreground="#C0CAF5"
                                            Text="{Binding DisplaySsid}" />
                                        <Border
                                            Margin="10,2,0,0"
                                            Padding="6,2"
                                            VerticalAlignment="Center"
                                            Background="#414868"
                                            CornerRadius="3"
                                            Visibility="{Binding IsHidden, Converter={StaticResource BoolToVis}}">
                                            <TextBlock
                                                FontSize="10"
                                                Foreground="#9AA5CE"
                                                Text="🫥 隠しネットワーク" />
                                        </Border>
                                        <Border
                                            Margin="8,2,0,0"
                                            Padding="6,2"
                                            VerticalAlignment="Center"
                                            Background="#F7768E"
                                            CornerRadius="3"
                                            Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}">
                                            <TextBlock
                                                FontSize="10"
                                                FontWeight="Bold"
                                                Foreground="White"
                                                Text="🔴 接続中" />
                                        </Border>
                                    </StackPanel>

                                    <!--  BSSID + Vendor  -->
                                    <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                        <TextBlock
                                            FontFamily="Consolas"
                                            FontSize="12"
                                            Foreground="#9AA5CE">
                                            <Run Text="🆔 " />
                                            <Run Text="{Binding Bssid, Mode=OneWay}" />
                                        </TextBlock>
                                        <TextBlock
                                            Margin="16,0,0,0"
                                            FontSize="12"
                                            Foreground="#7DCFFF">
                                            <Run Text="🏢 " />
                                            <Run Text="{Binding Vendor, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>

                                    <!--  Channel / Width / Freq / Time  -->
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontSize="12"
                                        Foreground="#A9B1D6">
                                        <Run Text="📻 Ch " />
                                        <Run FontWeight="Bold" Foreground="#E0AF68" Text="{Binding Channel, Mode=OneWay}" />
                                        <Run Text="     📐 " />
                                        <Run FontWeight="Bold" Foreground="#9ECE6A" Text="{Binding ChannelWidth, Mode=OneWay}" />
                                        <Run Text=" MHz" />
                                        <Run Text="     🎛 " />
                                        <Run FontWeight="Bold" Foreground="#BB9AF7" Text="{Binding Frequency, Mode=OneWay}" />
                                        <Run Text=" MHz" />
                                        <Run Text="     🕒 " />
                                        <Run Foreground="#9AA5CE" Text="{Binding LastSeen, StringFormat=HH:mm:ss, Mode=OneWay}" />
                                    </TextBlock>

                                    <!--  Badges row: band / standard / security  -->
                                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                        <Border
                                            Margin="0,0,6,0"
                                            Padding="8,3"
                                            Background="{Binding BandBrush}"
                                            CornerRadius="4">
                                            <TextBlock
                                                FontSize="11"
                                                FontWeight="Bold"
                                                Foreground="White">
                                                <Run Text="📡 " />
                                                <Run Text="{Binding Band, Mode=OneWay}" />
                                            </TextBlock>
                                        </Border>
                                        <Border
                                            Margin="0,0,6,0"
                                            Padding="8,3"
                                            Background="#414868"
                                            CornerRadius="4">
                                            <TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Foreground="#C0CAF5"
                                                Text="{Binding StandardLabel}" />
                                        </Border>
                                        <Border
                                            Margin="0,0,6,0"
                                            Padding="8,3"
                                            Background="{Binding SecurityBrush}"
                                            CornerRadius="4">
                                            <TextBlock
                                                FontSize="11"
                                                FontWeight="Bold"
                                                Foreground="White">
                                                <Run Text="{Binding SecurityIcon, Mode=OneWay}" />
                                                <Run Text=" " />
                                                <Run Text="{Binding SecurityLabel, Mode=OneWay}" />
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <!--  Right: dBm  -->
                                <StackPanel
                                    Grid.Column="3"
                                    Margin="16,0,4,0"
                                    VerticalAlignment="Center">
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontSize="26"
                                        FontWeight="Bold"
                                        Foreground="{Binding SignalBrush}">
                                        <Run Text="{Binding Level, Mode=OneWay}" />
                                        <Run FontSize="13"
                                             FontWeight="Normal"
                                             Foreground="#9AA5CE"
                                             Text=" dBm" />
                                    </TextBlock>
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        HorizontalAlignment="Right"
                                        FontSize="11"
                                        Foreground="#565F89">
                                        <Run Text="bars " />
                                        <Run FontWeight="Bold" Foreground="{Binding SignalBrush}" Text="{Binding SignalBars, Mode=OneWay}" />
                                        <Run Text=" / 4" />
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
