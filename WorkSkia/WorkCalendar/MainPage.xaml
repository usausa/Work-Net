<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:WorkCalendar.Controls"
             xmlns:vm="clr-namespace:WorkCalendar.ViewModels"
             x:Class="WorkCalendar.MainPage"
             BackgroundColor="White">

    <ContentPage.Resources>
        <ResourceDictionary>
            <!-- BottomNav: アクティブ状態のアイコン/ラベル -->
            <Style x:Key="NavIconActive" TargetType="Label">
                <Setter Property="FontSize" Value="20" />
                <Setter Property="HorizontalTextAlignment" Value="Center" />
                <Setter Property="TextColor" Value="#D81B60" />
            </Style>
            <Style x:Key="NavLabelActive" TargetType="Label">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="HorizontalTextAlignment" Value="Center" />
                <Setter Property="TextColor" Value="#D81B60" />
            </Style>
            <!-- BottomNav: 非アクティブ状態のアイコン/ラベル -->
            <Style x:Key="NavIconInactive" TargetType="Label">
                <Setter Property="FontSize" Value="20" />
                <Setter Property="HorizontalTextAlignment" Value="Center" />
                <Setter Property="TextColor" Value="#888888" />
            </Style>
            <Style x:Key="NavLabelInactive" TargetType="Label">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="HorizontalTextAlignment" Value="Center" />
                <Setter Property="TextColor" Value="#888888" />
            </Style>
            <!-- FAB: 中央ボタンのラベル -->
            <Style x:Key="FabLabel" TargetType="Label">
                <Setter Property="TextColor" Value="White" />
                <Setter Property="FontSize" Value="26" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="HorizontalTextAlignment" Value="Center" />
                <Setter Property="VerticalTextAlignment" Value="Center" />
            </Style>
            <!-- FAB: 中央ボタンの円形ボーダー -->
            <Style x:Key="FabBorder" TargetType="Border">
                <Setter Property="BackgroundColor" Value="Black" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="WidthRequest" Value="48" />
                <Setter Property="HeightRequest" Value="48" />
                <Setter Property="VerticalOptions" Value="Center" />
                <Setter Property="StrokeShape" Value="RoundRectangle 24" />
            </Style>
            <!-- カレンダー下区切り線 -->
            <Style x:Key="CalendarDivider" TargetType="BoxView">
                <Setter Property="HeightRequest" Value="0.5" />
                <Setter Property="Color" Value="#E0E0E0" />
            </Style>
            <!-- BottomNavバー -->
            <Style x:Key="BottomNavBar" TargetType="Grid">
                <Setter Property="Padding" Value="0,8,0,12" />
                <Setter Property="BackgroundColor" Value="White" />
            </Style>
            <!-- BottomNavアイテムのスタック -->
            <Style x:Key="NavItemStack" TargetType="VerticalStackLayout">
                <Setter Property="HorizontalOptions" Value="Center" />
                <Setter Property="Spacing" Value="2" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.BindingContext>
        <vm:MainPageViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="*,Auto,Auto" RowSpacing="0">

        <!-- Calendar control -->
        <controls:CalendarView Grid.Row="0"
                               ViewModel="{Binding MonthViewModel}"
                               PrevMonthCommand="{Binding PrevMonthCommand}"
                               NextMonthCommand="{Binding NextMonthCommand}"
                               DayTappedCommand="{Binding DayTappedCommand}"
                               EventTappedCommand="{Binding EventTappedCommand}" />

        <!-- Divider below the last week -->
        <BoxView Grid.Row="1" Style="{StaticResource CalendarDivider}" />

        <!-- Bottom navigation -->
        <Grid Grid.Row="2" Style="{StaticResource BottomNavBar}" ColumnDefinitions="*,*,Auto,*,*">
            <VerticalStackLayout Grid.Column="0" Style="{StaticResource NavItemStack}">
                <Label Text="📅" Style="{StaticResource NavIconActive}" />
                <Label Text="カレンダー" Style="{StaticResource NavLabelActive}" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1" Style="{StaticResource NavItemStack}">
                <Label Text="✓" Style="{StaticResource NavIconInactive}" />
                <Label Text="ToDo" Style="{StaticResource NavLabelInactive}" />
            </VerticalStackLayout>
            <Border Grid.Column="2" Style="{StaticResource FabBorder}">
                <Label Text="+" Style="{StaticResource FabLabel}" />
            </Border>
            <VerticalStackLayout Grid.Column="3" Style="{StaticResource NavItemStack}">
                <Label Text="📖" Style="{StaticResource NavIconInactive}" />
                <Label Text="ノート＆日記" Style="{StaticResource NavLabelInactive}" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="4" Style="{StaticResource NavItemStack}">
                <Label Text="…" Style="{StaticResource NavIconInactive}" />
                <Label Text="その他" Style="{StaticResource NavLabelInactive}" />
            </VerticalStackLayout>
        </Grid>

    </Grid>

</ContentPage>
