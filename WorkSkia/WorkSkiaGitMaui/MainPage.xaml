<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:WorkSkiaGitMaui.Controls"
             xmlns:conv="clr-namespace:WorkSkiaGitMaui.Converters"
             xmlns:graph="clr-namespace:WorkSkiaGitMaui.Graph"
             xmlns:vm="clr-namespace:WorkSkiaGitMaui.ViewModels"
             x:Class="WorkSkiaGitMaui.MainPage"
             x:DataType="vm:MainPageViewModel"
             Title="Git Graph (MAUI)"
             BackgroundColor="White">
    <ContentPage.Resources>
        <conv:RefKindBrushConverter x:Key="RefBackgroundConverter" Foreground="False" />
        <conv:RefKindBrushConverter x:Key="RefForegroundConverter" Foreground="True" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                BackgroundColor="#FF2D2D30"
                Stroke="#FF2D2D30"
                StrokeThickness="0"
                Padding="10,6">
            <Label TextColor="White"
                   FontFamily="OpenSansRegular"
                   FontSize="13"
                   Text="{Binding HeaderText}" />
        </Border>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Rows}"
                        HorizontalScrollBarVisibility="Always"
                        VerticalScrollBarVisibility="Always"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="0" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="graph:GraphRow">
                    <Grid HeightRequest="26"
                          ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto"
                          ColumnSpacing="0">
                        <controls:GraphRowSurface Grid.Column="0"
                                                  RowData="{Binding .}"
                                                  VerticalOptions="Fill" />

                        <HorizontalStackLayout Grid.Column="1"
                                               Margin="6,0,4,0"
                                               VerticalOptions="Center"
                                               BindableLayout.ItemsSource="{Binding Refs}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="graph:GraphRef">
                                    <Border Margin="0,0,4,0"
                                            Padding="6,1"
                                            Stroke="#FF333333"
                                            StrokeThickness="1"
                                            BackgroundColor="{Binding Kind, Converter={StaticResource RefBackgroundConverter}}"
                                            StrokeShape="RoundRectangle 4">
                                        <Label Text="{Binding Name}"
                                               FontFamily="OpenSansRegular"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               TextColor="{Binding Kind, Converter={StaticResource RefForegroundConverter}}" />
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>

                        <Label Grid.Column="2"
                               Margin="0,0,8,0"
                               VerticalOptions="Center"
                               TextColor="#FF888888"
                               FontFamily="OpenSansRegular"
                               FontSize="12"
                               Text="{Binding ShortSha}" />

                        <Label Grid.Column="3"
                               Margin="0,0,16,0"
                               VerticalOptions="Center"
                               TextColor="Black"
                               FontFamily="OpenSansRegular"
                               FontSize="12"
                               LineBreakMode="TailTruncation"
                               Text="{Binding Summary}" />

                        <Label Grid.Column="4"
                               Margin="0,0,16,0"
                               VerticalOptions="Center"
                               TextColor="#FF666666"
                               FontFamily="OpenSansRegular"
                               FontSize="12"
                               Text="{Binding Author}" />

                        <Label Grid.Column="5"
                               Margin="0,0,16,0"
                               VerticalOptions="Center"
                               TextColor="#FF666666"
                               FontFamily="OpenSansRegular"
                               FontSize="12"
                               Text="{Binding When, StringFormat='{0:yyyy-MM-dd HH:mm}'}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
