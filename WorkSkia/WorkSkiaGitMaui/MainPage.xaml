<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:WorkSkiaGitMaui.Controls"
             xmlns:conv="clr-namespace:WorkSkiaGitMaui.Converters"
             xmlns:graph="clr-namespace:WorkSkiaGitMaui.Graph"
             xmlns:vm="clr-namespace:WorkSkiaGitMaui.ViewModels"
             x:Class="WorkSkiaGitMaui.MainPage"
             x:DataType="vm:MainPageViewModel"
             Title="Git Graph (MAUI)"
             BackgroundColor="White">
    <ContentPage.Resources>
        <conv:RefKindBrushConverter x:Key="RefBackgroundConverter" Foreground="False" />
        <conv:RefKindBrushConverter x:Key="RefForegroundConverter" Foreground="True" />
        <!-- ヘッダーバーのラベル -->
        <Style x:Key="HeaderLabelStyle" TargetType="Label">
            <Setter Property="TextColor" Value="White" />
            <Setter Property="FontFamily" Value="OpenSansRegular" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <!-- RefバッジのLabel -->
        <Style x:Key="RefBadgeLabelStyle" TargetType="Label">
            <Setter Property="FontFamily" Value="OpenSansRegular" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontAttributes" Value="Bold" />
        </Style>
        <!-- SHA・Author・Date などの補助情報 -->
        <Style x:Key="MetaLabelStyle" TargetType="Label">
            <Setter Property="VerticalOptions" Value="Center" />
            <Setter Property="FontFamily" Value="OpenSansRegular" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextColor" Value="#FF666666" />
        </Style>
        <!-- コミットサマリー -->
        <Style x:Key="SummaryLabelStyle" TargetType="Label">
            <Setter Property="VerticalOptions" Value="Center" />
            <Setter Property="TextColor" Value="Black" />
            <Setter Property="FontFamily" Value="OpenSansRegular" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="LineBreakMode" Value="TailTruncation" />
        </Style>
        <!-- SHAのみ色が異なる -->
        <Style x:Key="ShaLabelStyle" TargetType="Label" BasedOn="{StaticResource MetaLabelStyle}">
            <Setter Property="TextColor" Value="#FF888888" />
        </Style>
        <!-- ヘッダーバー：ダーク背景 -->
        <Style x:Key="HeaderBarBorderStyle" TargetType="Border">
            <Setter Property="BackgroundColor" Value="#FF2D2D30" />
            <Setter Property="Stroke" Value="#FF2D2D30" />
            <Setter Property="StrokeThickness" Value="0" />
            <Setter Property="Padding" Value="10,6" />
        </Style>
        <!-- Refバッジ：枠線付き丸角 -->
        <Style x:Key="RefBadgeBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Padding" Value="6,1" />
            <Setter Property="Stroke" Value="#FF333333" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="StrokeShape" Value="RoundRectangle 4" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                Style="{StaticResource HeaderBarBorderStyle}">
            <Label Style="{StaticResource HeaderLabelStyle}"
                   Text="{Binding HeaderText}" />
        </Border>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Rows}"
                        HorizontalScrollBarVisibility="Always"
                        VerticalScrollBarVisibility="Always"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="0" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="graph:GraphRow">
                    <Grid HeightRequest="26"
                          ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto"
                          ColumnSpacing="0">
                        <controls:GraphRowSurface Grid.Column="0"
                                                  RowData="{Binding .}"
                                                  VerticalOptions="Fill" />

                        <HorizontalStackLayout Grid.Column="1"
                                               Margin="6,0,4,0"
                                               VerticalOptions="Center"
                                               BindableLayout.ItemsSource="{Binding Refs}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="graph:GraphRef">
                                    <Border Style="{StaticResource RefBadgeBorderStyle}"
                                            BackgroundColor="{Binding Kind, Converter={StaticResource RefBackgroundConverter}}">
                                        <Label Text="{Binding Name}"
                                               Style="{StaticResource RefBadgeLabelStyle}"
                                               TextColor="{Binding Kind, Converter={StaticResource RefForegroundConverter}}" />
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>

                        <Label Grid.Column="2"
                               Margin="0,0,8,0"
                               Style="{StaticResource ShaLabelStyle}"
                               Text="{Binding ShortSha}" />

                        <Label Grid.Column="3"
                               Margin="0,0,16,0"
                               Style="{StaticResource SummaryLabelStyle}"
                               Text="{Binding Summary}" />

                        <Label Grid.Column="4"
                               Margin="0,0,16,0"
                               Style="{StaticResource MetaLabelStyle}"
                               Text="{Binding Author}" />

                        <Label Grid.Column="5"
                               Margin="0,0,16,0"
                               Style="{StaticResource MetaLabelStyle}"
                               Text="{Binding When, StringFormat='{0:yyyy-MM-dd HH:mm}'}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
