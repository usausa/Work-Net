<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WorkGauge.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:WorkGauge.Controls"
    xmlns:vm="clr-namespace:WorkGauge.ViewModels"
    Title="Gauge Demo"
    x:DataType="vm:MainPageViewModel">

    <ScrollView>
        <Grid
            Padding="10"
            ColumnDefinitions="*,*"
            ColumnSpacing="10"
            RowDefinitions="Auto,Auto,Auto"
            RowSpacing="10">

            <!--  ===== Row 0: Pressure (light) / Humidity (dark blue) =====  -->

            <!--  Sample 1: Pressure — グレーベゼル、薄赤→赤 range 内側、ラベル外側、針長め  -->
            <VerticalStackLayout
                Grid.Row="0"
                Grid.Column="0"
                Spacing="4">
                <controls:Gauge
                    ArcInnerExtent="0.64"
                    ArcOuterExtent="0.76"
                    BezelInnerThickness="0"
                    BezelOuterEndColor="Black"
                    BezelOuterStartColor="Black"
                    BezelOuterThickness="6"
                    HeightRequest="220"
                    LabelExtent="0.88"
                    LabelFontSize="9"
                    LabelFormat="{}{0:N0}"
                    LabelInterval="20"
                    MajorTickColor="Black"
                    MajorTickInnerExtent="0.63"
                    MajorTickInterval="10"
                    MajorTickOuterExtent="0.77"
                    MaxValue="1050"
                    MinValue="950"
                    MinorTickColor="Gray"
                    MinorTickInnerExtent="0.64"
                    MinorTickInterval="2"
                    MinorTickOuterExtent="0.76"
                    MinorTickThickness="0.5"
                    NeedleEndExtent="0.84"
                    NeedleStartWidth="5"
                    PivotRadius="5"
                    Unit="hPa"
                    UnitFontSize="9"
                    UnitPosition="Bottom"
                    ValueFontSize="18"
                    ValueFormat="{}{0:N0}"
                    ValueOffsetY="0.5"
                    Value="{Binding Pressure}">
                    <controls:Gauge.Ranges>
                        <controls:GaugeRange
                            EndColor="#CC0000"
                            EndValue="1050"
                            StartColor="#FFB0B0"
                            StartValue="950" />
                    </controls:Gauge.Ranges>
                </controls:Gauge>
                <Label
                    FontSize="11"
                    HorizontalOptions="Center"
                    Text="Pressure" />
                <Slider
                    Maximum="1050"
                    Minimum="950"
                    Value="{Binding Pressure, Mode=TwoWay}" />
            </VerticalStackLayout>

            <!--  Sample 2: Humidity — ダーク、青グラデ range 内側、メモリはrangeをまたぐ  -->
            <VerticalStackLayout
                Grid.Row="0"
                Grid.Column="1"
                Spacing="4">
                <controls:Gauge
                    ArcInnerExtent="0.62"
                    ArcOuterExtent="0.74"
                    ArcTrackColor="#30FFFFFF"
                    BezelInnerThickness="0"
                    BezelOuterEndColor="#404860"
                    BezelOuterStartColor="#A0A8C0"
                    BezelOuterThickness="6"
                    GaugeBackgroundColor="#1A1E30"
                    HeightRequest="220"
                    LabelColor="White"
                    LabelExtent="0.88"
                    LabelFontSize="9"
                    LabelFormat="{}{0:N0}%"
                    LabelInterval="20"
                    MajorTickColor="White"
                    MajorTickInnerExtent="0.62"
                    MajorTickInterval="10"
                    MajorTickOuterExtent="0.78"
                    MaxValue="100"
                    MinValue="0"
                    MinorTickInterval="0"
                    NeedleEndExtent="0.86"
                    NeedleLeftColor="#1848C0"
                    NeedleRightColor="#2858D0"
                    NeedleStartWidth="6"
                    PivotColor="#1848C0"
                    PivotRadius="5"
                    Unit="%"
                    UnitColor="#80B0FF"
                    UnitFontSize="9"
                    UnitPosition="Right"
                    ValueColor="White"
                    ValueFontSize="14"
                    ValueFormat="{}{0:N0}"
                    ValueOffsetY="0.5"
                    Value="{Binding Humidity}">
                    <controls:Gauge.Ranges>
                        <controls:GaugeRange
                            EndColor="#2060CC"
                            EndValue="40"
                            StartColor="#2060CC"
                            StartValue="0" />
                        <controls:GaugeRange
                            EndColor="#40A0FF"
                            EndValue="70"
                            StartColor="#2880FF"
                            StartValue="40" />
                        <controls:GaugeRange
                            EndColor="#60C0FF"
                            EndValue="100"
                            StartColor="#40A0FF"
                            StartValue="70" />
                    </controls:Gauge.Ranges>
                </controls:Gauge>
                <Label
                    FontSize="11"
                    HorizontalOptions="Center"
                    Text="Humidity" />
                <Slider
                    Maximum="100"
                    Minimum="0"
                    Value="{Binding Humidity, Mode=TwoWay}" />
            </VerticalStackLayout>

            <!--  ===== Row 1: Temperature (dark) / Wind Direction (dark) =====  -->

            <!--  Sample 3: Temperature — ダーク、太ベゼル、青→緑→橙→赤 range  -->
            <VerticalStackLayout
                Grid.Row="1"
                Grid.Column="0"
                Spacing="4">
                <controls:Gauge
                    ArcInnerExtent="0.84"
                    ArcOuterExtent="0.92"
                    ArcTrackColor="#30FFFFFF"
                    BezelInnerThickness="0"
                    BezelOuterEndColor="#404860"
                    BezelOuterStartColor="#A0A8C0"
                    BezelOuterThickness="6"
                    GaugeBackgroundColor="#1A1E30"
                    HeightRequest="220"
                    LabelColor="White"
                    LabelExtent="0.64"
                    LabelFontSize="10"
                    LabelFormat="{}{0:N0}"
                    LabelInterval="10"
                    MajorTickColor="White"
                    MajorTickInnerExtent="0.72"
                    MajorTickInterval="5"
                    MajorTickOuterExtent="0.80"
                    MaxValue="40"
                    MinValue="-10"
                    MinorTickColor="#8090B0"
                    MinorTickInnerExtent="0.76"
                    MinorTickInterval="1"
                    MinorTickOuterExtent="0.80"
                    NeedleLeftColor="#CC5000"
                    NeedleRightColor="#DD6010"
                    NeedleStartWidth="8"
                    PivotColor="#CC5000"
                    PivotRadius="8"
                    Unit="°C"
                    UnitColor="#FFA040"
                    UnitFontSize="9"
                    UnitPosition="Right"
                    ValueColor="White"
                    ValueFontSize="14"
                    ValueFormat="{}{0:N1}"
                    ValueOffsetY="0.4"
                    Value="{Binding Temperature}">
                    <controls:Gauge.Ranges>
                        <controls:GaugeRange
                            EndColor="#40C060"
                            EndValue="10"
                            StartColor="#3080FF"
                            StartValue="-10" />
                        <controls:GaugeRange
                            EndColor="#C8D040"
                            EndValue="25"
                            StartColor="#40C060"
                            StartValue="10" />
                        <controls:GaugeRange
                            EndColor="#FFA040"
                            EndValue="35"
                            StartColor="#C8D040"
                            StartValue="25" />
                        <controls:GaugeRange
                            EndColor="#FF3010"
                            EndValue="40"
                            StartColor="#FFA040"
                            StartValue="35" />
                    </controls:Gauge.Ranges>
                </controls:Gauge>
                <Label
                    FontSize="11"
                    HorizontalOptions="Center"
                    Text="Temperature" />
                <Slider
                    Maximum="40"
                    Minimum="-10"
                    Value="{Binding Temperature, Mode=TwoWay}" />
            </VerticalStackLayout>

            <!--  Sample 4: Wind Direction — 濃グレー背景、太ベゼル無グラデ、長いメモリ、360°  -->
            <VerticalStackLayout
                Grid.Row="1"
                Grid.Column="1"
                Spacing="4">
                <controls:Gauge
                    x:Name="WindGauge"
                    AnimationDuration="0"
                    ArcEndColor="Transparent"
                    ArcStartColor="Transparent"
                    ArcTrackColor="Transparent"
                    BezelInnerThickness="0"
                    BezelOuterEndColor="#252525"
                    BezelOuterStartColor="#252525"
                    BezelOuterThickness="10"
                    GaugeBackgroundColor="#383838"
                    HeightRequest="220"
                    LabelColor="White"
                    LabelExtent="0.90"
                    LabelFontSize="18"
                    LabelInterval="90"
                    MajorTickColor="White"
                    MajorTickInnerExtent="0.62"
                    MajorTickInterval="45"
                    MajorTickOuterExtent="0.78"
                    MajorTickThickness="3"
                    MaxValue="360"
                    MinValue="0"
                    MinorTickColor="#C0C0C0"
                    MinorTickInnerExtent="0.66"
                    MinorTickInterval="22.5"
                    MinorTickOuterExtent="0.78"
                    NeedleEndExtent="0.54"
                    NeedleLeftColor="#CC2020"
                    NeedleRightColor="#E03030"
                    NeedleStartWidth="12"
                    PivotColor="#CC2020"
                    PivotRadius="10"
                    ShowValue="False"
                    StartAngle="0"
                    SweepAngle="360"
                    Value="{Binding WindDirection}" />
                <Label
                    FontSize="11"
                    HorizontalOptions="Center"
                    Text="Wind Direction" />
                <Slider
                    Maximum="360"
                    Minimum="0"
                    Value="{Binding WindDirection, Mode=TwoWay}" />
            </VerticalStackLayout>

            <!--  ===== Row 2: Speed (102816 style) / Tachometer (102839 style) =====  -->

            <!--  Sample 5: Speed — 薄水色背景、緑→黄→赤 range、黒文字大きめ (102816 style)  -->
            <VerticalStackLayout
                Grid.Row="2"
                Grid.Column="0"
                Spacing="4">
                <controls:Gauge
                    AnimationDuration="1000"
                    ArcInnerExtent="0.82"
                    ArcOuterExtent="0.94"
                    ArcTrackColor="#25000000"
                    BezelInnerEndColor="#B8D4F0"
                    BezelInnerStartColor="#5A6878"
                    BezelInnerThickness="3"
                    BezelOuterEndColor="#7888A8"
                    BezelOuterStartColor="#D8EEFF"
                    BezelOuterThickness="6"
                    GaugeBackgroundColor="#5070A0"
                    GaugeBackgroundColor2="#E4F2FC"
                    HeightRequest="220"
                    LabelColor="Black"
                    LabelExtent="0.64"
                    LabelFontSize="12"
                    LabelFormat="{}{0:N0}"
                    LabelInterval="40"
                    MajorTickColor="White"
                    MajorTickInnerExtent="0.76"
                    MajorTickInterval="20"
                    MajorTickOuterExtent="0.94"
                    MaxValue="200"
                    MinValue="0"
                    MinorTickColor="LightGray"
                    MinorTickInnerExtent="0.82"
                    MinorTickInterval="10"
                    MinorTickOuterExtent="0.94"
                    NeedleEndExtent="0.90"
                    NeedleLeftColor="#CC1818"
                    NeedleRightColor="#DD2828"
                    NeedleStartWidth="8"
                    PivotColor="#CC1818"
                    PivotRadius="6"
                    Unit="km/h"
                    UnitColor="#204060"
                    UnitFontSize="9"
                    UnitPosition="Bottom"
                    ValueColor="Black"
                    ValueFontSize="28"
                    ValueFormat="{}{0:N0}"
                    ValueOffsetY="0.5"
                    Value="{Binding SpeedKmh}">
                    <controls:Gauge.Ranges>
                        <controls:GaugeRange
                            EndColor="#C8D020"
                            EndValue="80"
                            StartColor="#30CC30"
                            StartValue="0" />
                        <controls:GaugeRange
                            EndColor="#FF8020"
                            EndValue="140"
                            StartColor="#C8D020"
                            StartValue="80" />
                        <controls:GaugeRange
                            EndColor="#FF2020"
                            EndValue="200"
                            StartColor="#FF8020"
                            StartValue="140" />
                    </controls:Gauge.Ranges>
                </controls:Gauge>
                <Label
                    FontSize="11"
                    HorizontalOptions="Center"
                    Text="Speed  (102816 style)" />
                <Slider
                    Maximum="200"
                    Minimum="0"
                    Value="{Binding SpeedKmh, Mode=TwoWay}" />
            </VerticalStackLayout>

            <!--  Sample 6: Tachometer — ダーク、-150°～120°、赤ゾーンのみ、ラベル内側 (102839 style)  -->
            <VerticalStackLayout
                Grid.Row="2"
                Grid.Column="1"
                Spacing="4">
                <controls:Gauge
                    AnimationDuration="1000"
                    ArcInnerExtent="0.80"
                    ArcOuterExtent="0.88"
                    ArcTrackColor="Transparent"
                    BezelInnerThickness="0"
                    BezelOuterEndColor="#505058"
                    BezelOuterStartColor="#D0D0D8"
                    BezelOuterThickness="6"
                    GaugeBackgroundColor="#141414"
                    GaugeBackgroundColor2="#D0D0D8"
                    HeightRequest="220"
                    LabelColor="White"
                    LabelExtent="0.65"
                    LabelFontSize="14"
                    LabelFormat="{}{0:N0}"
                    LabelInterval="2"
                    MajorTickColor="White"
                    MajorTickInnerExtent="0.74"
                    MajorTickInterval="1"
                    MajorTickOuterExtent="0.90"
                    MajorTickThickness="3"
                    MaxValue="8"
                    MinValue="0"
                    MinorTickColor="White"
                    MinorTickInnerExtent="0.78"
                    MinorTickInterval="0.25"
                    MinorTickOuterExtent="0.90"
                    NeedleEndExtent="0.94"
                    NeedleLeftColor="#CC4400"
                    NeedleRightColor="#DD5010"
                    NeedleStartWidth="8"
                    PivotColor="#CC4400"
                    PivotRadius="8"
                    ShowValue="False"
                    StartAngle="-150"
                    SweepAngle="270"
                    Value="{Binding Rpm}">
                    <controls:Gauge.Ranges>
                        <controls:GaugeRange
                            EndColor="#FF2020"
                            EndValue="8"
                            StartColor="#CC2020"
                            StartValue="6" />
                    </controls:Gauge.Ranges>
                </controls:Gauge>
                <Label
                    FontSize="11"
                    HorizontalOptions="Center"
                    Text="Tachometer  (102839 style)" />
                <Slider
                    Maximum="8"
                    Minimum="0"
                    Value="{Binding Rpm, Mode=TwoWay}" />
            </VerticalStackLayout>

        </Grid>
    </ScrollView>

</ContentPage>
