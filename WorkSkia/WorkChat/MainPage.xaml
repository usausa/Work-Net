<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WorkChat.ViewModels"
             xmlns:models="clr-namespace:WorkChat.Models"
             xmlns:selectors="clr-namespace:WorkChat.Selectors"
             x:Class="WorkChat.MainPage"
             x:DataType="vm:MainPageViewModel"
             Title="WorkChat"
             BackgroundColor="White">

    <ContentPage.Resources>
        <ResourceDictionary>

            <Color x:Key="BubbleSend">#4CAF50</Color>
            <Color x:Key="BubbleSendText">#FFFFFF</Color>
            <Color x:Key="BubbleReceive">#F0F0F0</Color>
            <Color x:Key="BubbleReceiveText">#1A1A1A</Color>
            <Color x:Key="MetaText">#888888</Color>
            <Color x:Key="AuthorText">#666666</Color>
            <Color x:Key="DividerLine">#D0D0D0</Color>
            <Color x:Key="InputBackground">#F5F5F5</Color>
            <Color x:Key="InputBorder">#E0E0E0</Color>
            <Color x:Key="ReactionBackground">#FFFFFF</Color>
            <Color x:Key="ReactionBorder">#D0D0D0</Color>

            <x:Double x:Key="BubbleMaxWidth">280</x:Double>

            <!-- メタ情報ラベル（時刻・既読・システムメッセージ） -->
            <Style x:Key="MetaLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextColor" Value="{StaticResource MetaText}" />
            </Style>
            <!-- 送受信バブル内のテキスト -->
            <Style x:Key="BubbleContentLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="LineBreakMode" Value="WordWrap" />
            </Style>
            <!-- 送信バブル用テキスト（白） -->
            <Style x:Key="SendBubbleLabelStyle" TargetType="Label" BasedOn="{StaticResource BubbleContentLabelStyle}">
                <Setter Property="TextColor" Value="{StaticResource BubbleSendText}" />
            </Style>
            <!-- 受信バブル用テキスト（ダーク） -->
            <Style x:Key="ReceiveBubbleLabelStyle" TargetType="Label" BasedOn="{StaticResource BubbleContentLabelStyle}">
                <Setter Property="TextColor" Value="{StaticResource BubbleReceiveText}" />
            </Style>
            <!-- 送信者名ラベル -->
            <Style x:Key="AuthorLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="TextColor" Value="{StaticResource AuthorText}" />
            </Style>
            <!-- リアクション数ラベル -->
            <Style x:Key="ReactionCountLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="10" />
                <Setter Property="TextColor" Value="{StaticResource MetaText}" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>
            <!-- システムメッセージラベル（日付ピル） -->
            <Style x:Key="SystemMessageLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextColor" Value="{StaticResource MetaText}" />
            </Style>

            <!-- アバター：40×40 円形クリップ -->
            <Style x:Key="AvatarBorderStyle" TargetType="Border">
                <Setter Property="WidthRequest" Value="40" />
                <Setter Property="HeightRequest" Value="40" />
                <Setter Property="Stroke" Value="Transparent" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 20" />
                <Setter Property="VerticalOptions" Value="Start" />
            </Style>

            <!-- 送信バブル：緑背景・右丸角 -->
            <Style x:Key="SendBubbleBorderStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource BubbleSend}" />
                <Setter Property="Stroke" Value="Transparent" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="MaximumWidthRequest" Value="{StaticResource BubbleMaxWidth}" />
                <Setter Property="StrokeShape" Value="RoundRectangle 14,4,14,14" />
            </Style>

            <!-- 受信バブル：グレー背景・左丸角 -->
            <Style x:Key="ReceiveBubbleBorderStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource BubbleReceive}" />
                <Setter Property="Stroke" Value="Transparent" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="MaximumWidthRequest" Value="{StaticResource BubbleMaxWidth}" />
                <Setter Property="StrokeShape" Value="RoundRectangle 4,14,14,14" />
            </Style>

            <!-- リアクションピル -->
            <Style x:Key="ReactionPillBorderStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource ReactionBackground}" />
                <Setter Property="Stroke" Value="{StaticResource ReactionBorder}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="Padding" Value="6,1" />
                <Setter Property="Margin" Value="0,0,4,0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 10" />
            </Style>

            <!-- システム日付ピル -->
            <Style x:Key="SystemDatePillBorderStyle" TargetType="Border">
                <Setter Property="Stroke" Value="{StaticResource DividerLine}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="Padding" Value="12,4" />
                <Setter Property="StrokeShape" Value="RoundRectangle 12" />
            </Style>

            <!-- 入力フィールド Border -->
            <Style x:Key="InputFieldBorderStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource InputBackground}" />
                <Setter Property="Stroke" Value="{StaticResource InputBorder}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 20" />
            </Style>

            <!-- スタンプ画像：120×120 -->
            <Style x:Key="StampImageStyle" TargetType="Image">
                <Setter Property="HeightRequest" Value="120" />
                <Setter Property="WidthRequest" Value="120" />
                <Setter Property="Aspect" Value="AspectFit" />
            </Style>

            <!-- ツールバーアクションボタン（カメラ・送信）：40×40 -->
            <Style x:Key="ToolbarActionButtonStyle" TargetType="ImageButton">
                <Setter Property="WidthRequest" Value="40" />
                <Setter Property="HeightRequest" Value="40" />
                <Setter Property="Padding" Value="8" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="Aspect" Value="AspectFit" />
            </Style>

            <!-- スタンプピッカーボタン：36×36 -->
            <Style x:Key="StickerActionButtonStyle" TargetType="ImageButton">
                <Setter Property="WidthRequest" Value="36" />
                <Setter Property="HeightRequest" Value="36" />
                <Setter Property="Padding" Value="6" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="Aspect" Value="AspectFit" />
            </Style>

            <!-- Reaction pill -->
            <DataTemplate x:Key="ReactionTemplate" x:DataType="models:MessageReaction">
                <Border Style="{StaticResource ReactionPillBorderStyle}">
                    <HorizontalStackLayout Spacing="3" VerticalOptions="Center">
                        <Label Text="{Binding Emoji}" FontSize="12" />
                        <Label Text="{Binding Count}"
                               Style="{StaticResource ReactionCountLabelStyle}" />
                    </HorizontalStackLayout>
                </Border>
            </DataTemplate>

            <!-- Send: time/read column to the LEFT of the bubble, bubble width capped -->
            <DataTemplate x:Key="SendTemplate" x:DataType="models:ChatMessage">
                <Grid Padding="60,4,8,4">
                    <VerticalStackLayout HorizontalOptions="End" Spacing="2">

                        <!-- [time/read] [bubble or stamp] -->
                        <Grid HorizontalOptions="End"
                              ColumnDefinitions="Auto,Auto"
                              ColumnSpacing="6">

                            <VerticalStackLayout Grid.Column="0"
                                                 VerticalOptions="End"
                                                 Spacing="0">
                                <Label Text="既読"
                                       IsVisible="{Binding ShowReadIndicator}"
                                       Style="{StaticResource MetaLabelStyle}"
                                       HorizontalOptions="End" />
                                <Label Text="{Binding TimeText}"
                                       Style="{StaticResource MetaLabelStyle}"
                                       HorizontalOptions="End" />
                            </VerticalStackLayout>

                            <Border Grid.Column="1"
                                    IsVisible="{Binding HasText}"
                                    Style="{StaticResource SendBubbleBorderStyle}">
                                <Label Text="{Binding TextContent}"
                                       Style="{StaticResource SendBubbleLabelStyle}" />
                            </Border>

                            <Image Grid.Column="1"
                                   IsVisible="{Binding IsStamp}"
                                   Source="{Binding StampSource}"
                                   Style="{StaticResource StampImageStyle}" />
                        </Grid>

                        <!-- Reactions below -->
                        <HorizontalStackLayout BindableLayout.ItemsSource="{Binding Reactions}"
                                               BindableLayout.ItemTemplate="{StaticResource ReactionTemplate}"
                                               IsVisible="{Binding HasReactions}"
                                               HorizontalOptions="End"
                                               Spacing="0" />
                    </VerticalStackLayout>
                </Grid>
            </DataTemplate>

            <!-- Receive: avatar, then [bubble or stamp] with timestamp on the RIGHT -->
            <DataTemplate x:Key="ReceiveTemplate" x:DataType="models:ChatMessage">
                <Grid Padding="8,4,60,4" ColumnDefinitions="40,*" ColumnSpacing="8">

                    <!-- Avatar image clipped to circle -->
                    <Border Grid.Column="0"
                            Style="{StaticResource AvatarBorderStyle}">
                        <Image Source="{Binding AvatarSource}" Aspect="AspectFill" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="2"
                                         HorizontalOptions="Start">

                        <Label Text="{Binding Author}"
                               Style="{StaticResource AuthorLabelStyle}" />

                        <!-- [bubble or stamp] [time] -->
                        <Grid HorizontalOptions="Start"
                              ColumnDefinitions="Auto,Auto"
                              ColumnSpacing="6">

                            <Border Grid.Column="0"
                                    IsVisible="{Binding HasText}"
                                    Style="{StaticResource ReceiveBubbleBorderStyle}">
                                <Label Text="{Binding TextContent}"
                                       Style="{StaticResource ReceiveBubbleLabelStyle}" />
                            </Border>

                            <Image Grid.Column="0"
                                   IsVisible="{Binding IsStamp}"
                                   Source="{Binding StampSource}"
                                   Style="{StaticResource StampImageStyle}" />

                            <Label Grid.Column="1"
                                   Text="{Binding TimeText}"
                                   Style="{StaticResource MetaLabelStyle}"
                                   VerticalOptions="End" />
                        </Grid>

                        <HorizontalStackLayout BindableLayout.ItemsSource="{Binding Reactions}"
                                               BindableLayout.ItemTemplate="{StaticResource ReactionTemplate}"
                                               IsVisible="{Binding HasReactions}"
                                               HorizontalOptions="Start"
                                               Spacing="0" />
                    </VerticalStackLayout>
                </Grid>
            </DataTemplate>

            <!-- System: line — framed date pill — line -->
            <DataTemplate x:Key="SystemTemplate" x:DataType="models:ChatMessage">
                <Grid Padding="16,16" ColumnDefinitions="*,Auto,*" ColumnSpacing="12">
                    <BoxView Grid.Column="0"
                             HeightRequest="1"
                             Color="{StaticResource DividerLine}"
                             VerticalOptions="Center" />
                    <Border Grid.Column="1"
                            Style="{StaticResource SystemDatePillBorderStyle}">
                        <Label Text="{Binding TextContent}"
                               Style="{StaticResource SystemMessageLabelStyle}" />
                    </Border>
                    <BoxView Grid.Column="2"
                             HeightRequest="1"
                             Color="{StaticResource DividerLine}"
                             VerticalOptions="Center" />
                </Grid>
            </DataTemplate>

            <selectors:ChatMessageTemplateSelector x:Key="MessageTemplateSelector"
                                                   SendTemplate="{StaticResource SendTemplate}"
                                                   ReceiveTemplate="{StaticResource ReceiveTemplate}"
                                                   SystemTemplate="{StaticResource SystemTemplate}" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,1,Auto">

        <!-- Message list -->
        <CollectionView x:Name="MessagesView"
                        Grid.Row="0"
                        ItemsSource="{Binding Messages}"
                        ItemTemplate="{StaticResource MessageTemplateSelector}"
                        ItemsUpdatingScrollMode="KeepLastItemInView"
                        VerticalScrollBarVisibility="Default" />

        <!-- Top border of input area -->
        <BoxView Grid.Row="1" Color="{StaticResource InputBorder}" />

        <!-- Input area: camera | [entry + sticker] | send -->
        <Grid Grid.Row="2"
              ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="4"
              Padding="8"
              BackgroundColor="White">

            <ImageButton Grid.Column="0"
                         Source="ic_camera.png"
                         Command="{Binding PickImageCommand}"
                         Style="{StaticResource ToolbarActionButtonStyle}" />

            <Border Grid.Column="1"
                    Style="{StaticResource InputFieldBorderStyle}">
                <Grid ColumnDefinitions="*,Auto">
                    <Entry Grid.Column="0"
                           Text="{Binding InputText}"
                           Placeholder="メッセージを入力"
                           BackgroundColor="Transparent"
                           Margin="14,0,0,0"
                           ReturnType="Send"
                           ReturnCommand="{Binding SendCommand}" />
                    <ImageButton Grid.Column="1"
                                 Source="ic_sticker.png"
                                 Command="{Binding PickStickerCommand}"
                                 Style="{StaticResource StickerActionButtonStyle}" />
                </Grid>
            </Border>

            <ImageButton Grid.Column="2"
                         Source="ic_send.png"
                         Command="{Binding SendCommand}"
                         Style="{StaticResource ToolbarActionButtonStyle}" />
        </Grid>
    </Grid>
</ContentPage>
