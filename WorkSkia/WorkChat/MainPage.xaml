<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WorkChat.ViewModels"
             xmlns:models="clr-namespace:WorkChat.Models"
             xmlns:selectors="clr-namespace:WorkChat.Selectors"
             x:Class="WorkChat.MainPage"
             x:DataType="vm:MainPageViewModel"
             Title="WorkChat"
             BackgroundColor="{AppThemeBinding Light=#E5DDD5, Dark=#1F1F1F}">

    <ContentPage.Resources>
        <ResourceDictionary>

            <!-- Reaction pill -->
            <DataTemplate x:Key="ReactionTemplate" x:DataType="models:MessageReaction">
                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2A2A}"
                        Stroke="{AppThemeBinding Light=#D0D0D0, Dark=#444444}"
                        StrokeThickness="1"
                        Padding="6,1"
                        Margin="0,0,4,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="3" VerticalOptions="Center">
                        <Label Text="{Binding Emoji}" FontSize="12" />
                        <Label Text="{Binding Count}"
                               FontSize="10"
                               TextColor="{AppThemeBinding Light=#666666, Dark=#BBBBBB}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>
            </DataTemplate>

            <!-- Send (right-aligned) -->
            <DataTemplate x:Key="SendTemplate" x:DataType="models:ChatMessage">
                <Grid Padding="60,4,8,4" ColumnSpacing="6">
                    <VerticalStackLayout HorizontalOptions="End" Spacing="2">

                        <!-- Text bubble -->
                        <Border IsVisible="{Binding HasText}"
                                BackgroundColor="#DCF8C6"
                                Stroke="Transparent"
                                StrokeThickness="0"
                                Padding="10,6"
                                HorizontalOptions="End">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14,14,4,14" />
                            </Border.StrokeShape>
                            <Label Text="{Binding TextContent}"
                                   TextColor="#1A1A1A"
                                   FontSize="14"
                                   LineBreakMode="WordWrap" />
                        </Border>

                        <!-- Stamp -->
                        <Image IsVisible="{Binding IsStamp}"
                               Source="{Binding StampSource}"
                               HeightRequest="120"
                               WidthRequest="120"
                               Aspect="AspectFit"
                               HorizontalOptions="End" />

                        <!-- Reactions -->
                        <HorizontalStackLayout BindableLayout.ItemsSource="{Binding Reactions}"
                                               BindableLayout.ItemTemplate="{StaticResource ReactionTemplate}"
                                               IsVisible="{Binding HasReactions}"
                                               HorizontalOptions="End"
                                               Spacing="0" />

                        <!-- Timestamp -->
                        <Label Text="{Binding TimeText}"
                               FontSize="10"
                               TextColor="{AppThemeBinding Light=#777777, Dark=#AAAAAA}"
                               HorizontalOptions="End" />
                    </VerticalStackLayout>
                </Grid>
            </DataTemplate>

            <!-- Receive (left-aligned with avatar) -->
            <DataTemplate x:Key="ReceiveTemplate" x:DataType="models:ChatMessage">
                <Grid Padding="8,4,60,4" ColumnDefinitions="36,*" ColumnSpacing="8">

                    <!-- Avatar -->
                    <Border Grid.Column="0"
                            WidthRequest="36"
                            HeightRequest="36"
                            BackgroundColor="{Binding AvatarColor}"
                            Stroke="Transparent"
                            StrokeThickness="0"
                            VerticalOptions="Start">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18" />
                        </Border.StrokeShape>
                        <Label Text="{Binding AvatarInitial}"
                               TextColor="White"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <!-- Body -->
                    <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="Start">

                        <!-- Author -->
                        <Label Text="{Binding Author}"
                               FontSize="11"
                               TextColor="{AppThemeBinding Light=#555555, Dark=#BBBBBB}" />

                        <!-- Bubble + time row -->
                        <HorizontalStackLayout Spacing="6" VerticalOptions="End">

                            <!-- Text bubble -->
                            <Border IsVisible="{Binding HasText}"
                                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2A2A}"
                                    Stroke="Transparent"
                                    StrokeThickness="0"
                                    Padding="10,6">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14,14,14,4" />
                                </Border.StrokeShape>
                                <Label Text="{Binding TextContent}"
                                       TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#EEEEEE}"
                                       FontSize="14"
                                       LineBreakMode="WordWrap" />
                            </Border>

                            <!-- Stamp -->
                            <Image IsVisible="{Binding IsStamp}"
                                   Source="{Binding StampSource}"
                                   HeightRequest="120"
                                   WidthRequest="120"
                                   Aspect="AspectFit"
                                   HorizontalOptions="Start" />

                            <!-- Timestamp -->
                            <Label Text="{Binding TimeText}"
                                   FontSize="10"
                                   TextColor="{AppThemeBinding Light=#777777, Dark=#AAAAAA}"
                                   VerticalOptions="End" />
                        </HorizontalStackLayout>

                        <!-- Reactions -->
                        <HorizontalStackLayout BindableLayout.ItemsSource="{Binding Reactions}"
                                               BindableLayout.ItemTemplate="{StaticResource ReactionTemplate}"
                                               IsVisible="{Binding HasReactions}"
                                               HorizontalOptions="Start"
                                               Spacing="0" />
                    </VerticalStackLayout>
                </Grid>
            </DataTemplate>

            <!-- System (centered pill) -->
            <DataTemplate x:Key="SystemTemplate" x:DataType="models:ChatMessage">
                <Grid Padding="0,12">
                    <Border HorizontalOptions="Center"
                            Padding="12,4"
                            BackgroundColor="#80909090"
                            Stroke="Transparent"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>
                        <Label Text="{Binding TextContent}"
                               TextColor="White"
                               FontSize="11" />
                    </Border>
                </Grid>
            </DataTemplate>

            <selectors:ChatMessageTemplateSelector x:Key="MessageTemplateSelector"
                                                   SendTemplate="{StaticResource SendTemplate}"
                                                   ReceiveTemplate="{StaticResource ReceiveTemplate}"
                                                   SystemTemplate="{StaticResource SystemTemplate}" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <!-- Message list -->
        <CollectionView x:Name="MessagesView"
                        Grid.Row="0"
                        ItemsSource="{Binding Messages}"
                        ItemTemplate="{StaticResource MessageTemplateSelector}"
                        ItemsUpdatingScrollMode="KeepLastItemInView"
                        VerticalScrollBarVisibility="Default" />

        <!-- Input area -->
        <Grid Grid.Row="1"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="8"
              Padding="8"
              BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2A2A}">

            <Border Grid.Column="0"
                    BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#1F1F1F}"
                    Stroke="{AppThemeBinding Light=#D0D0D0, Dark=#444444}"
                    StrokeThickness="1"
                    Padding="10,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Entry Text="{Binding InputText}"
                       Placeholder="メッセージを入力"
                       BackgroundColor="Transparent"
                       ReturnType="Send"
                       ReturnCommand="{Binding SendCommand}" />
            </Border>

            <Button Grid.Column="1"
                    Text="送信"
                    Command="{Binding SendCommand}"
                    MinimumWidthRequest="72" />
        </Grid>
    </Grid>
</ContentPage>
