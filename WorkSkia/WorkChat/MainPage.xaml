<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WorkChat.ViewModels"
             xmlns:models="clr-namespace:WorkChat.Models"
             xmlns:selectors="clr-namespace:WorkChat.Selectors"
             x:Class="WorkChat.MainPage"
             x:DataType="vm:MainPageViewModel"
             Title="WorkChat"
             BackgroundColor="White">

    <ContentPage.Resources>
        <ResourceDictionary>

            <Color x:Key="BubbleSend">#4CAF50</Color>
            <Color x:Key="BubbleSendText">#FFFFFF</Color>
            <Color x:Key="BubbleReceive">#F0F0F0</Color>
            <Color x:Key="BubbleReceiveText">#1A1A1A</Color>
            <Color x:Key="MetaText">#888888</Color>
            <Color x:Key="AuthorText">#666666</Color>
            <Color x:Key="DividerLine">#D0D0D0</Color>
            <Color x:Key="InputBackground">#F5F5F5</Color>
            <Color x:Key="InputBorder">#E0E0E0</Color>
            <Color x:Key="ReactionBackground">#FFFFFF</Color>
            <Color x:Key="ReactionBorder">#D0D0D0</Color>

            <x:Double x:Key="BubbleMaxWidth">280</x:Double>

            <!-- メタ情報ラベル（時刻・既読） -->
            <Style x:Key="MetaLabel" TargetType="Label">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextColor" Value="{StaticResource MetaText}" />
            </Style>
            <!-- 送信側：メタラベル（右揃え） -->
            <Style x:Key="SendMetaLabel" TargetType="Label" BasedOn="{StaticResource MetaLabel}">
                <Setter Property="HorizontalOptions" Value="End" />
            </Style>
            <!-- 受信側：時刻ラベル（下揃え） -->
            <Style x:Key="ReceiveTimeLabel" TargetType="Label" BasedOn="{StaticResource MetaLabel}">
                <Setter Property="VerticalOptions" Value="End" />
            </Style>
            <!-- 送受信バブル内のテキスト -->
            <Style x:Key="BubbleContentLabel" TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="LineBreakMode" Value="WordWrap" />
            </Style>
            <!-- 送信バブル用テキスト（白） -->
            <Style x:Key="SendBubbleLabel" TargetType="Label" BasedOn="{StaticResource BubbleContentLabel}">
                <Setter Property="TextColor" Value="{StaticResource BubbleSendText}" />
            </Style>
            <!-- 受信バブル用テキスト（ダーク） -->
            <Style x:Key="ReceiveBubbleLabel" TargetType="Label" BasedOn="{StaticResource BubbleContentLabel}">
                <Setter Property="TextColor" Value="{StaticResource BubbleReceiveText}" />
            </Style>
            <!-- 送信者名ラベル -->
            <Style x:Key="AuthorLabel" TargetType="Label">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="TextColor" Value="{StaticResource AuthorText}" />
            </Style>
            <!-- リアクション絵文字ラベル -->
            <Style x:Key="ReactionEmojiLabel" TargetType="Label">
                <Setter Property="FontSize" Value="12" />
            </Style>
            <!-- リアクション数ラベル -->
            <Style x:Key="ReactionCountLabel" TargetType="Label">
                <Setter Property="FontSize" Value="10" />
                <Setter Property="TextColor" Value="{StaticResource MetaText}" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>
            <!-- システムメッセージラベル（日付ピル） -->
            <Style x:Key="SystemMessageLabel" TargetType="Label">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextColor" Value="{StaticResource MetaText}" />
            </Style>

            <!-- アバター：40×40 円形クリップ -->
            <Style x:Key="AvatarBorder" TargetType="Border">
                <Setter Property="WidthRequest" Value="40" />
                <Setter Property="HeightRequest" Value="40" />
                <Setter Property="Stroke" Value="Transparent" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 20" />
                <Setter Property="VerticalOptions" Value="Start" />
            </Style>
            <!-- 送信バブル：緑背景・右丸角 -->
            <Style x:Key="SendBubbleBorder" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource BubbleSend}" />
                <Setter Property="Stroke" Value="Transparent" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="MaximumWidthRequest" Value="{StaticResource BubbleMaxWidth}" />
                <Setter Property="StrokeShape" Value="RoundRectangle 14,4,14,14" />
            </Style>
            <!-- 受信バブル：グレー背景・左丸角 -->
            <Style x:Key="ReceiveBubbleBorder" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource BubbleReceive}" />
                <Setter Property="Stroke" Value="Transparent" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="MaximumWidthRequest" Value="{StaticResource BubbleMaxWidth}" />
                <Setter Property="StrokeShape" Value="RoundRectangle 4,14,14,14" />
            </Style>
            <!-- リアクションピル -->
            <Style x:Key="ReactionPillBorder" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource ReactionBackground}" />
                <Setter Property="Stroke" Value="{StaticResource ReactionBorder}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="Padding" Value="6,1" />
                <Setter Property="Margin" Value="0,0,4,0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 10" />
            </Style>
            <!-- システム日付ピル -->
            <Style x:Key="SystemDatePillBorder" TargetType="Border">
                <Setter Property="Stroke" Value="{StaticResource DividerLine}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="Padding" Value="12,4" />
                <Setter Property="StrokeShape" Value="RoundRectangle 12" />
            </Style>
            <!-- 入力フィールド Border -->
            <Style x:Key="InputFieldBorder" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource InputBackground}" />
                <Setter Property="Stroke" Value="{StaticResource InputBorder}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 20" />
            </Style>

            <!-- スタンプ画像：120×120 -->
            <Style x:Key="StampImage" TargetType="Image">
                <Setter Property="HeightRequest" Value="120" />
                <Setter Property="WidthRequest" Value="120" />
                <Setter Property="Aspect" Value="AspectFit" />
            </Style>
            <!-- ツールバーアクションボタン（カメラ・送信）：40×40 -->
            <Style x:Key="ToolbarActionButton" TargetType="ImageButton">
                <Setter Property="WidthRequest" Value="40" />
                <Setter Property="HeightRequest" Value="40" />
                <Setter Property="Padding" Value="8" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="Aspect" Value="AspectFit" />
            </Style>
            <!-- スタンプピッカーボタン：36×36 -->
            <Style x:Key="StickerActionButton" TargetType="ImageButton">
                <Setter Property="WidthRequest" Value="36" />
                <Setter Property="HeightRequest" Value="36" />
                <Setter Property="Padding" Value="6" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="Aspect" Value="AspectFit" />
            </Style>

            <!-- リアクションピル内コンテンツ -->
            <Style x:Key="ReactionPillContent" TargetType="HorizontalStackLayout">
                <Setter Property="Spacing" Value="3" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>
            <!-- 送信メッセージ行のGrid -->
            <Style x:Key="SendMessageRow" TargetType="Grid">
                <Setter Property="Padding" Value="60,4,8,4" />
            </Style>
            <!-- 送信：バブル+時刻のGrid -->
            <Style x:Key="SendBubbleGrid" TargetType="Grid">
                <Setter Property="HorizontalOptions" Value="End" />
                <Setter Property="ColumnSpacing" Value="6" />
            </Style>
            <!-- 送信：全体 VerticalStackLayout -->
            <Style x:Key="SendMessageStack" TargetType="VerticalStackLayout">
                <Setter Property="HorizontalOptions" Value="End" />
                <Setter Property="Spacing" Value="2" />
            </Style>
            <!-- 送信：時刻/既読 VerticalStackLayout -->
            <Style x:Key="SendMetaStack" TargetType="VerticalStackLayout">
                <Setter Property="VerticalOptions" Value="End" />
                <Setter Property="Spacing" Value="0" />
            </Style>
            <!-- 送信：リアクションリスト -->
            <Style x:Key="SendReactionList" TargetType="HorizontalStackLayout">
                <Setter Property="HorizontalOptions" Value="End" />
                <Setter Property="Spacing" Value="0" />
            </Style>
            <!-- 受信メッセージ行のGrid -->
            <Style x:Key="ReceiveMessageRow" TargetType="Grid">
                <Setter Property="Padding" Value="8,4,60,4" />
                <Setter Property="ColumnSpacing" Value="8" />
            </Style>
            <!-- 受信：バブル+時刻のGrid -->
            <Style x:Key="ReceiveBubbleGrid" TargetType="Grid">
                <Setter Property="HorizontalOptions" Value="Start" />
                <Setter Property="ColumnSpacing" Value="6" />
            </Style>
            <!-- 受信：全体 VerticalStackLayout -->
            <Style x:Key="ReceiveContentStack" TargetType="VerticalStackLayout">
                <Setter Property="HorizontalOptions" Value="Start" />
                <Setter Property="Spacing" Value="2" />
            </Style>
            <!-- 受信：リアクションリスト -->
            <Style x:Key="ReceiveReactionList" TargetType="HorizontalStackLayout">
                <Setter Property="HorizontalOptions" Value="Start" />
                <Setter Property="Spacing" Value="0" />
            </Style>
            <!-- システムメッセージ行のGrid -->
            <Style x:Key="SystemMessageRow" TargetType="Grid">
                <Setter Property="Padding" Value="16,16" />
                <Setter Property="ColumnSpacing" Value="12" />
            </Style>
            <!-- システム区切り線 -->
            <Style x:Key="MessageDivider" TargetType="BoxView">
                <Setter Property="HeightRequest" Value="1" />
                <Setter Property="Color" Value="{StaticResource DividerLine}" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>
            <!-- 入力バー -->
            <Style x:Key="InputBar" TargetType="Grid">
                <Setter Property="Padding" Value="8" />
                <Setter Property="ColumnSpacing" Value="4" />
                <Setter Property="BackgroundColor" Value="White" />
            </Style>
            <!-- メッセージ入力フィールド -->
            <Style x:Key="MessageInputEntry" TargetType="Entry">
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="Margin" Value="14,0,0,0" />
                <Setter Property="ReturnType" Value="Send" />
            </Style>

            <!-- Reaction pill -->
            <DataTemplate x:Key="ReactionTemplate" x:DataType="models:MessageReaction">
                <Border Style="{StaticResource ReactionPillBorder}">
                    <HorizontalStackLayout Style="{StaticResource ReactionPillContent}">
                        <Label Text="{Binding Emoji}" Style="{StaticResource ReactionEmojiLabel}" />
                        <Label Text="{Binding Count}"
                               Style="{StaticResource ReactionCountLabel}" />
                    </HorizontalStackLayout>
                </Border>
            </DataTemplate>

            <!-- Send: time/read column to the LEFT of the bubble, bubble width capped -->
            <DataTemplate x:Key="SendTemplate" x:DataType="models:ChatMessage">
                <Grid Style="{StaticResource SendMessageRow}">
                    <VerticalStackLayout Style="{StaticResource SendMessageStack}">

                        <!-- [time/read] [bubble or stamp] -->
                        <Grid Style="{StaticResource SendBubbleGrid}"
                              ColumnDefinitions="Auto,Auto">

                            <VerticalStackLayout Grid.Column="0"
                                                 Style="{StaticResource SendMetaStack}">
                                <Label Text="既読"
                                       IsVisible="{Binding ShowReadIndicator}"
                                       Style="{StaticResource SendMetaLabel}" />
                                <Label Text="{Binding TimeText}"
                                       Style="{StaticResource SendMetaLabel}" />
                            </VerticalStackLayout>

                            <Border Grid.Column="1"
                                    IsVisible="{Binding HasText}"
                                    Style="{StaticResource SendBubbleBorder}">
                                <Label Text="{Binding TextContent}"
                                       Style="{StaticResource SendBubbleLabel}" />
                            </Border>

                            <Image Grid.Column="1"
                                   IsVisible="{Binding IsStamp}"
                                   Source="{Binding StampSource}"
                                   Style="{StaticResource StampImage}" />
                        </Grid>

                        <!-- Reactions below -->
                        <HorizontalStackLayout Style="{StaticResource SendReactionList}"
                                               BindableLayout.ItemsSource="{Binding Reactions}"
                                               BindableLayout.ItemTemplate="{StaticResource ReactionTemplate}"
                                               IsVisible="{Binding HasReactions}" />
                    </VerticalStackLayout>
                </Grid>
            </DataTemplate>

            <!-- Receive: avatar, then [bubble or stamp] with timestamp on the RIGHT -->
            <DataTemplate x:Key="ReceiveTemplate" x:DataType="models:ChatMessage">
                <Grid Style="{StaticResource ReceiveMessageRow}" ColumnDefinitions="40,*">

                    <!-- Avatar image clipped to circle -->
                    <Border Grid.Column="0"
                            Style="{StaticResource AvatarBorder}">
                        <Image Source="{Binding AvatarSource}" Aspect="AspectFill" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1"
                                        Style="{StaticResource ReceiveContentStack}">

                        <Label Text="{Binding Author}"
                               Style="{StaticResource AuthorLabel}" />

                        <!-- [bubble or stamp] [time] -->
                        <Grid Style="{StaticResource ReceiveBubbleGrid}"
                              ColumnDefinitions="Auto,Auto">

                            <Border Grid.Column="0"
                                    IsVisible="{Binding HasText}"
                                    Style="{StaticResource ReceiveBubbleBorder}">
                                <Label Text="{Binding TextContent}"
                                       Style="{StaticResource ReceiveBubbleLabel}" />
                            </Border>

                            <Image Grid.Column="0"
                                   IsVisible="{Binding IsStamp}"
                                   Source="{Binding StampSource}"
                                   Style="{StaticResource StampImage}" />

                            <Label Grid.Column="1"
                                   Text="{Binding TimeText}"
                                   Style="{StaticResource ReceiveTimeLabel}" />
                        </Grid>

                        <HorizontalStackLayout Style="{StaticResource ReceiveReactionList}"
                                               BindableLayout.ItemsSource="{Binding Reactions}"
                                               BindableLayout.ItemTemplate="{StaticResource ReactionTemplate}"
                                               IsVisible="{Binding HasReactions}" />
                    </VerticalStackLayout>
                </Grid>
            </DataTemplate>

            <!-- System: line — framed date pill — line -->
            <DataTemplate x:Key="SystemTemplate" x:DataType="models:ChatMessage">
                <Grid Style="{StaticResource SystemMessageRow}" ColumnDefinitions="*,Auto,*">
                    <BoxView Grid.Column="0"
                             Style="{StaticResource MessageDivider}" />
                    <Border Grid.Column="1"
                            Style="{StaticResource SystemDatePillBorder}">
                        <Label Text="{Binding TextContent}"
                               Style="{StaticResource SystemMessageLabel}" />
                    </Border>
                    <BoxView Grid.Column="2"
                             Style="{StaticResource MessageDivider}" />
                </Grid>
            </DataTemplate>

            <selectors:ChatMessageTemplateSelector x:Key="MessageTemplateSelector"
                                                   SendTemplate="{StaticResource SendTemplate}"
                                                   ReceiveTemplate="{StaticResource ReceiveTemplate}"
                                                   SystemTemplate="{StaticResource SystemTemplate}" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,1,Auto">

        <!-- Message list -->
        <CollectionView x:Name="MessagesView"
                        Grid.Row="0"
                        ItemsSource="{Binding Messages}"
                        ItemTemplate="{StaticResource MessageTemplateSelector}"
                        ItemsUpdatingScrollMode="KeepLastItemInView"
                        VerticalScrollBarVisibility="Default" />

        <!-- Top border of input area -->
        <BoxView Grid.Row="1" Color="{StaticResource InputBorder}" />

        <!-- Input area: camera | [entry + sticker] | send -->
        <Grid Grid.Row="2"
              Style="{StaticResource InputBar}"
              ColumnDefinitions="Auto,*,Auto">

            <ImageButton Grid.Column="0"
                         Source="ic_camera.png"
                         Command="{Binding PickImageCommand}"
                         Style="{StaticResource ToolbarActionButton}" />

            <Border Grid.Column="1"
                    Style="{StaticResource InputFieldBorder}">
                <Grid ColumnDefinitions="*,Auto">
                    <Entry Grid.Column="0"
                           Text="{Binding InputText}"
                           Placeholder="メッセージを入力"
                           Style="{StaticResource MessageInputEntry}"
                           ReturnCommand="{Binding SendCommand}" />
                    <ImageButton Grid.Column="1"
                                 Source="ic_sticker.png"
                                 Command="{Binding PickStickerCommand}"
                                 Style="{StaticResource StickerActionButton}" />
                </Grid>
            </Border>

            <ImageButton Grid.Column="2"
                         Source="ic_send.png"
                         Command="{Binding SendCommand}"
                         Style="{StaticResource ToolbarActionButton}" />
        </Grid>
    </Grid>
</ContentPage>
