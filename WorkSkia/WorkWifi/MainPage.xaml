<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:WorkWifi"
             x:Class="WorkWifi.MainPage"
             x:DataType="local:MainPageViewModel"
             BackgroundColor="#F2F2F7"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <!-- ヘッダーのタイトル -->
            <Style x:Key="HeaderTitleStyle" TargetType="Label">
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="#1C1C1E" />
            </Style>
            <!-- ヘッダーのサブタイトル -->
            <Style x:Key="HeaderSubtitleStyle" TargetType="Label">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextColor" Value="#8E8E93" />
            </Style>
            <!-- ヘッダー件数バッジのLabel -->
            <Style x:Key="CountBadgeLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="White" />
            </Style>
            <!-- アイテムのSSID名 -->
            <Style x:Key="SsidLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="#1C1C1E" />
                <Setter Property="LineBreakMode" Value="TailTruncation" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>
            <!-- インラインバッジのLabel（接続中・Passpoint共通） -->
            <Style x:Key="InlineBadgeLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="10" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>
            <!-- グレーのメタ情報（#8E8E93） -->
            <Style x:Key="MetaLabelStyle" TargetType="Label">
                <Setter Property="VerticalOptions" Value="Center" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextColor" Value="#8E8E93" />
            </Style>

            <!-- ヘッダーバー：白背景・底面Shadow -->
            <Style x:Key="HeaderBarBorderStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="Stroke" Value="Transparent" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="Rectangle" />
            </Style>

            <!-- 件数バッジ：青丸角 -->
            <Style x:Key="CountBadgeBorderStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="#007AFF" />
                <Setter Property="Stroke" Value="Transparent" />
                <Setter Property="StrokeShape" Value="RoundRectangle 13" />
                <Setter Property="Padding" Value="12,5" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

            <!-- APカード：白カード・丸角12 -->
            <Style x:Key="ApCardBorderStyle" TargetType="Border">
                <Setter Property="Margin" Value="12,0,12,0" />
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="Stroke" Value="Transparent" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 12" />
                <Setter Property="Padding" Value="14,10" />
            </Style>

            <!-- 接続中バッジ：緑 -->
            <Style x:Key="ConnectedBadgeBorderStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="#34C759" />
                <Setter Property="Stroke" Value="Transparent" />
                <Setter Property="StrokeShape" Value="RoundRectangle 6" />
                <Setter Property="Padding" Value="6,2" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

            <!-- Passspoint バッジ：黄 -->
            <Style x:Key="PasspointBadgeBorderStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="#FFE082" />
                <Setter Property="Stroke" Value="Transparent" />
                <Setter Property="StrokeShape" Value="RoundRectangle 6" />
                <Setter Property="Padding" Value="6,2" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.BindingContext>
        <local:MainPageViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0"
                Style="{StaticResource HeaderBarBorderStyle}">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.06" Radius="6" Offset="0,2" />
            </Border.Shadow>
            <Grid Padding="18,14" ColumnDefinitions="Auto,*,Auto">
                <Label Grid.Column="0"
                       Text="📡"
                       FontSize="28"
                       VerticalOptions="Center" />
                <VerticalStackLayout Grid.Column="1"
                                     Margin="12,0,0,0"
                                     Spacing="1"
                                     VerticalOptions="Center">
                    <Label Text="Wi-Fi"
                           Style="{StaticResource HeaderTitleStyle}" />
                    <Label Text="周辺のネットワーク"
                           Style="{StaticResource HeaderSubtitleStyle}" />
                </VerticalStackLayout>
                <Border Grid.Column="2"
                        Style="{StaticResource CountBadgeBorderStyle}">
                    <Label Text="{Binding AccessPoints.Count, StringFormat='{0}件'}"
                           Style="{StaticResource CountBadgeLabelStyle}" />
                </Border>
            </Grid>
        </Border>

        <!-- AP list -->
        <CollectionView Grid.Row="1"
                        Margin="0,6,0,0"
                        ItemsSource="{Binding AccessPoints}"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="6" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:WifiAccessPoint">
                    <Border Style="{StaticResource ApCardBorderStyle}">
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.06" Radius="4" Offset="0,1" />
                        </Border.Shadow>

                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12"
                              RowDefinitions="Auto,Auto,Auto"
                              RowSpacing="3">

                            <!-- Signal icon spans all rows -->
                            <Label Grid.Column="0" Grid.Row="0" Grid.RowSpan="3"
                                   Text="{Binding SignalIcon}"
                                   FontSize="34"
                                   TextColor="{Binding SignalColor}"
                                   VerticalOptions="Center" />

                            <!-- Row 1: SSID + inline badges -->
                            <HorizontalStackLayout Grid.Column="1" Grid.Row="0"
                                                   Spacing="6"
                                                   VerticalOptions="Center">
                                <Label Text="{Binding DisplaySsid}"
                                       Style="{StaticResource SsidLabelStyle}" />
                                <Label Text="{Binding SecurityIcon}"
                                       FontSize="14"
                                       TextColor="{Binding SecurityColor}"
                                       VerticalOptions="Center" />
                                <Border IsVisible="{Binding IsConnected}"
                                        Style="{StaticResource ConnectedBadgeBorderStyle}">
                                    <Label Text="接続中"
                                           Style="{StaticResource InlineBadgeLabelStyle}"
                                           TextColor="White" />
                                </Border>
                                <Border IsVisible="{Binding IsPasspointNetwork}"
                                        Style="{StaticResource PasspointBadgeBorderStyle}">
                                    <Label Text="Passpoint"
                                           Style="{StaticResource InlineBadgeLabelStyle}"
                                           TextColor="#5D4037" />
                                </Border>
                            </HorizontalStackLayout>

                            <!-- Row 1 right: dBm spans rows 0-1 -->
                            <Label Grid.Column="2" Grid.Row="0" Grid.RowSpan="2"
                                   VerticalOptions="Center"
                                   FontAttributes="Bold"
                                   TextColor="{Binding SignalColor}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding Level}" FontSize="24" />
                                        <Span Text=" dBm"
                                              FontSize="11"
                                              TextColor="#8E8E93"
                                              FontAttributes="None" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <!-- Row 2: 周波数帯 / 規格 / チャンネル -->
                            <Label Grid.Column="1" Grid.Row="1"
                                   FontSize="13"
                                   LineBreakMode="TailTruncation"
                                   VerticalOptions="Center">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding Band}" FontAttributes="Bold" TextColor="{Binding BandColor}" />
                                        <Span Text="  •  " TextColor="#C7C7CC" />
                                        <Span Text="{Binding StandardLabel}" FontAttributes="Bold" TextColor="#1C1C1E" />
                                        <Span Text="  •  Ch " TextColor="#8E8E93" />
                                        <Span Text="{Binding Channel}" FontAttributes="Bold" TextColor="#1C1C1E" />
                                        <Span Text=" (" TextColor="#8E8E93" />
                                        <Span Text="{Binding ChannelWidthLabel}" TextColor="#1C1C1E" />
                                        <Span Text=")" TextColor="#8E8E93" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <!-- Row 3: セキュリティ / BSSID -->
                            <Label Grid.Column="1" Grid.Row="2" Grid.ColumnSpan="2"
                                   FontSize="12"
                                   LineBreakMode="TailTruncation"
                                   VerticalOptions="Center">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding SecurityLabel}" FontAttributes="Bold" TextColor="{Binding SecurityColor}" />
                                        <Span Text="  •  " TextColor="#C7C7CC" />
                                        <Span Text="{Binding Bssid}" FontFamily="Monospace" TextColor="#8E8E93" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.Footer>
                <BoxView HeightRequest="10" Color="Transparent" />
            </CollectionView.Footer>
        </CollectionView>
    </Grid>
</ContentPage>
