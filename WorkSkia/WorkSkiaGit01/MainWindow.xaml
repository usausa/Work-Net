<Window x:Class="WorkSkiaGit01.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WorkSkiaGit01"
        xmlns:controls="clr-namespace:WorkSkiaGit01.Controls"
        mc:Ignorable="d"
        Title="Git Graph (SkiaSharp)" Height="800" Width="1280">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#FF2D2D30" Padding="10,6">
            <TextBlock x:Name="HeaderText"
                       Foreground="White"
                       FontFamily="Segoe UI"
                       FontSize="13"
                       Text="Loading..." />
        </Border>
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="White">
            <controls:SKElement x:Name="Surface" />
        </ScrollViewer>
    </DockPanel>
</Window>
