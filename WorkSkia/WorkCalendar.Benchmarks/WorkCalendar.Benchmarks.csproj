<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <UseMaui>true</UseMaui>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Maui.Controls" Version="$(MauiVersion)" />
    </ItemGroup>

    <ItemGroup>
        <Compile Include="..\WorkCalendar\Models\*.cs" Link="Models\%(Filename)%(Extension)" />
        <Compile Include="..\WorkCalendar\Services\IScheduleService.cs" Link="Services\IScheduleService.cs" />
        <Compile Include="..\WorkCalendar\Services\IHolidayService.cs" Link="Services\IHolidayService.cs" />
        <Compile Include="..\WorkCalendar\Services\ScheduleService.cs" Link="Services\ScheduleService.cs" />
        <Compile Include="..\WorkCalendar\Services\HolidayService.cs" Link="Services\HolidayService.cs" />
        <Compile Include="..\WorkCalendar\ViewModels\DayViewModel.cs" Link="ViewModels\DayViewModel.cs" />
        <Compile Include="..\WorkCalendar\ViewModels\EventPlacement.cs" Link="ViewModels\EventPlacement.cs" />
        <Compile Include="..\WorkCalendar\ViewModels\MonthViewBuilder.cs" Link="ViewModels\MonthViewBuilder.cs" />
        <Compile Include="..\WorkCalendar\ViewModels\MonthViewModel.cs" Link="ViewModels\MonthViewModel.cs" />
        <Compile Include="..\WorkCalendar\ViewModels\WeekViewModel.cs" Link="ViewModels\WeekViewModel.cs" />
    </ItemGroup>

</Project>
